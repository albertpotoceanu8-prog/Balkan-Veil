{
  "installCommand": "npm ci --prefix website",
  "buildCommand": "npm run build --prefix website",
  "outputDirectory": "website/dist",
  "redirects": [
    {
      "source": "/",
      "destination": "/ro",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
